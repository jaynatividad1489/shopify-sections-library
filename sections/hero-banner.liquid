{% comment %}
  Hero Banner Section
  - Full-width hero with background image or color
  - Supports heading, subheading, and dual CTA buttons
  - Mobile-first responsive design
  - Overlay opacity control via settings
{% endcomment %}

<section
  id="hero-banner-{{ section.id }}"
  class="hero-banner"
  style="
    min-height: {{ section.settings.section_height }}px;
    background-color: {{ section.settings.background_color }};
  "
>
  {%- if section.settings.background_image != blank -%}
    <div
      class="hero-banner__image"
      style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"
    ></div>
  {%- endif -%}

  <div
    class="hero-banner__overlay"
    style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
  ></div>

  <div class="hero-banner__content hero-banner__content--{{ section.settings.content_alignment }}">
    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1
        class="hero-banner__heading"
        style="color: {{ section.settings.heading_color }};"
      >
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p
        class="hero-banner__description"
        style="color: {{ section.settings.text_color }};"
      >
        {{ section.settings.description }}
      </p>
    {%- endif -%}

    <div class="hero-banner__buttons">
      {%- if section.settings.button_primary_label != blank -%}
        <a
          href="{{ section.settings.button_primary_url }}"
          class="hero-banner__btn hero-banner__btn--primary"
          style="
            background-color: {{ section.settings.button_primary_color }};
            color: {{ section.settings.button_primary_text_color }};
          "
        >
          {{ section.settings.button_primary_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_secondary_label != blank -%}
        <a
          href="{{ section.settings.button_secondary_url }}"
          class="hero-banner__btn hero-banner__btn--secondary"
          style="
            border-color: {{ section.settings.button_secondary_color }};
            color: {{ section.settings.button_secondary_color }};
          "
        >
          {{ section.settings.button_secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Height (px)",
      "min": 300,
      "max": 900,
      "step": 50,
      "default": 600
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color (fallback)",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for the Bold."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our latest collection crafted for those who dare to stand out."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#eeeeee"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_primary_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "button_primary_color",
      "label": "Button Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_primary_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_secondary_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "button_secondary_color",
      "label": "Button Border & Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
