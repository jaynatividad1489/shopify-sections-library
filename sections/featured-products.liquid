{% comment %}
  Featured Products Section
  - Displays a curated grid of products from any collection
  - Supports product cards with image, title, price, badge, and CTA
  - Responsive grid: 1 col mobile → 2 col tablet → 4 col desktop
  - Sale badge auto-displays when compare_at_price is set
  - "Quick Add" button adds product to cart via AJAX
{% endcomment %}

{%- assign featured_collection = collections[section.settings.collection] -%}
{%- assign product_limit = section.settings.products_to_show -%}

<section
  id="featured-products-{{ section.id }}"
  class="featured-products"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="featured-products__container">

    {%- if section.settings.heading != blank -%}
      <div class="featured-products__header">
        <h2
          class="featured-products__heading"
          style="color: {{ section.settings.heading_color }};"
        >
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="featured-products__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if featured_collection != blank and featured_collection.products.size > 0 -%}
      <div class="featured-products__grid featured-products__grid--{{ section.settings.columns }}">

        {%- for product in featured_collection.products limit: product_limit -%}
          {%- assign on_sale = false -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign on_sale = true -%}
          {%- endif -%}

          <div class="featured-products__card">

            {%- comment %} Product Image {%- endcomment %}
            <a href="{{ product.url }}" class="featured-products__image-wrap">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="featured-products__image featured-products__image--primary"
                  width="600"
                  height="600"
                  loading="lazy"
                >
                {%- if product.images[1] != blank and section.settings.show_secondary_image -%}
                  <img
                    src="{{ product.images[1] | image_url: width: 600 }}"
                    alt="{{ product.images[1].alt | escape }}"
                    class="featured-products__image featured-products__image--secondary"
                    width="600"
                    height="600"
                    loading="lazy"
                  >
                {%- endif -%}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'featured-products__placeholder' }}
              {%- endif -%}

              {%- comment %} Badges {%- endcomment %}
              <div class="featured-products__badges">
                {%- if on_sale -%}
                  <span class="featured-products__badge featured-products__badge--sale">Sale</span>
                {%- endif -%}
                {%- if product.available == false -%}
                  <span class="featured-products__badge featured-products__badge--sold-out">Sold Out</span>
                {%- endif -%}
              </div>
            </a>

            {%- comment %} Product Info {%- endcomment %}
            <div class="featured-products__info">
              {%- if section.settings.show_vendor and product.vendor != blank -%}
                <p class="featured-products__vendor">{{ product.vendor }}</p>
              {%- endif -%}

              <h3 class="featured-products__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="featured-products__price">
                {%- if on_sale -%}
                  <span class="featured-products__price--sale">{{ product.price | money }}</span>
                  <s class="featured-products__price--compare">{{ product.compare_at_price | money }}</s>
                {%- else -%}
                  <span class="featured-products__price--regular">{{ product.price | money }}</span>
                {%- endif -%}
              </div>

              {%- comment %} Quick Add Button {%- endcomment %}
              {%- if section.settings.show_quick_add and product.available -%}
                {%- if product.variants.size == 1 -%}
                  <form action="/cart/add" method="post">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button
                      type="submit"
                      class="featured-products__quick-add"
                    >
                      {{ section.settings.quick_add_label | default: 'Add to Cart' }}
                    </button>
                  </form>
                {%- else -%}
                  <a
                    href="{{ product.url }}"
                    class="featured-products__quick-add featured-products__quick-add--options"
                  >
                    Choose Options
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}

      </div>

      {%- comment %} View All Button {%- endcomment %}
      {%- if section.settings.show_view_all and featured_collection.products.size > product_limit -%}
        <div class="featured-products__footer">
          <a
            href="{{ featured_collection.url }}"
            class="featured-products__view-all"
          >
            {{ section.settings.view_all_label | default: 'View All' }}
          </a>
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="featured-products__empty">
        <p>No products found. Please select a collection in the theme editor.</p>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "featured-products-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most popular picks, just for you."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to Show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ],
      "default": "4"
    },
    {
      "type": "header",
      "content": "Product Card Options"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show Vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show Hover Image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show Quick Add Button",
      "default": true
    },
    {
      "type": "text",
      "id": "quick_add_label",
      "label": "Quick Add Button Label",
      "default": "Add to Cart"
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Button Label",
      "default": "View All Products"
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products"
    }
  ]
}
{% endschema %}
